# OpenRouter API Configuration (REQUIRED for AI Assistant)
# Get your API key from: https://openrouter.ai/keys
# Security: Never commit .env file with real API key to git
REACT_APP_OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# Optional: Override default model (default: openrouter/free)
# See available models: https://openrouter.ai/docs/models
# REACT_APP_OPENROUTER_MODEL=meta-llama/llama-2-7b-chat

# Optional: Cache TTL in milliseconds (default: 300000 = 5 minutes)
# REACT_APP_CACHE_TTL=300000
